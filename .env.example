# Copy to .env and fill in. Never commit .env.

# ─── database ─────────────────────────────────────────────────────────────────
# Own Neon branch — NOT the Node service's database.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/videoservice

# ─── queue ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── auth ─────────────────────────────────────────────────────────────────────
# Comma-separated for zero-downtime rotation. Unset = gate open (dev only).
SERVICE_API_KEY=

# ─── openai ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
CHAT_MODEL=gpt-5.4
CHAT_MODEL_MINI=gpt-5.4-mini
VISION_MODEL=gpt-5.4-mini
TRANSCRIBE_MODEL=whisper-1

# ─── storage: azure (preferred when all three are set) ────────────────────────
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=
# Optional override, e.g. Azurite: http://127.0.0.1:10000/devstoreaccount1
AZURE_STORAGE_ENDPOINT=

# ─── storage: s3 fallback ─────────────────────────────────────────────────────
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── pipeline tunables (match the Node service) ───────────────────────────────
CHUNK_MINUTES=10
